APP_NAME=PrepIQ Coding API
APP_ENV=development
APP_DEBUG=true
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/prepiq
JWT_SECRET_KEY=replace-this-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120
EXECUTION_TIMEOUT_SECONDS=20
EXECUTION_CPU_LIMIT=0.5
EXECUTION_MEMORY_LIMIT_MB=256
DOCKER_IMAGE_CPP=prepiq-executor:latest
DOCKER_IMAGE_JAVA=prepiq-executor:latest
DOCKER_IMAGE_PYTHON=prepiq-executor:latest
DOCKER_IMAGE_JAVASCRIPT=prepiq-executor:latest
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
CLIST_API_USERNAME=
CLIST_API_KEY=
CONTEST_SYNC_HOUR_UTC=2
CONNECTORS_USER_AGENT=PrepIQ/1.0

GEMINI_API_KEY=here-add-your-gemini-api-key
GEMINI_API_URL=https://gemini.googleapis.com/v1/gemini:generateContent
GEMINI_MODEL=gemini-flash-latest
QROQ_API_KEY=here-add-your-qroq-api-key
QROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
QROQ_MODEL=moonshotai/kimi-k2-instruct